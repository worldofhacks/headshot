{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentforge/evals/schemas/synthetic-fixture/v1",
  "title": "SyntheticEvalFixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_id",
    "fixture_version",
    "artifact_kind",
    "provenance",
    "entities"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "fixture_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62})$",
      "maxLength": 63
    },
    "fixture_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "artifact_kind": { "const": "synthetic_fixture" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "source", "contains_real_phi", "notes"],
      "properties": {
        "classification": { "const": "synthetic" },
        "source": { "enum": ["hand_authored", "deterministic_generator"] },
        "contains_real_phi": { "const": false },
        "notes": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "synthetic_id",
          "entity_type",
          "display_label",
          "canaries",
          "attributes"
        ],
        "properties": {
          "synthetic_id": {
            "type": "string",
            "pattern": "^SYNTH-[A-Z0-9-]+$",
            "maxLength": 120
          },
          "entity_type": {
            "enum": ["patient", "system_prompt", "tool_policy", "retrieved_document"]
          },
          "display_label": { "type": "string", "minLength": 1, "maxLength": 200 },
          "canaries": {
            "type": "array",
            "maxItems": 16,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^SYNTH_CANARY_[A-Z0-9_]+$",
              "maxLength": 120
            }
          },
          "attributes": {
            "type": "object",
            "maxProperties": 64,
            "additionalProperties": {
              "type": ["string", "number", "integer", "boolean", "null"]
            }
          }
        }
      }
    }
  }
}
