{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentforge/evals/schemas/ground-truth-slice/v1",
  "title": "GroundTruthSlice",
  "description": "Offline authored, human, or deterministic labels for Judge calibration. This artifact is not a live campaign result and does not prove calibration passed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "slice_id",
    "slice_version",
    "artifact_kind",
    "category",
    "calibration_status",
    "calibration_thresholds",
    "runtime_gate",
    "labels"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "slice_id": { "type": "string", "pattern": "^GT-SLICE-M11-[A-Z0-9-]+$" },
    "slice_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "artifact_kind": { "const": "ground_truth_slice" },
    "category": {
      "enum": [
        "prompt_injection",
        "data_exfiltration",
        "state_corruption",
        "tool_misuse",
        "denial_of_service",
        "identity_role_exploitation"
      ]
    },
    "calibration_status": { "const": "AUTHORED_NOT_RUN" },
    "calibration_thresholds": { "type": "null" },
    "runtime_gate": { "const": "NON_ORACLE_REMAINS_INDETERMINATE" },
    "labels": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label_id",
          "label_version",
          "case_ref",
          "sample_kind",
          "label_source",
          "evidence_status",
          "evidence_envelope",
          "expected_verdict",
          "precalibration_runtime_state",
          "live_campaign_result",
          "notes"
        ],
        "properties": {
          "label_id": { "type": "string", "pattern": "^GT-M11-[A-Z0-9-]+$" },
          "label_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "case_ref": {
            "type": "object",
            "additionalProperties": false,
            "required": ["case_id", "case_version"],
            "properties": {
              "case_id": { "type": "string", "pattern": "^AF-M11-[A-Z0-9-]+$" },
              "case_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
            }
          },
          "sample_kind": {
            "enum": [
              "deterministic_confirmation",
              "human_confirmation",
              "non_oracle_positive",
              "negative_control",
              "ambiguous",
              "evaluator_injection"
            ]
          },
          "label_source": {
            "enum": ["deterministic_oracle", "deterministic_canary", "human_expert", "policy_rule"]
          },
          "evidence_status": {
            "enum": [
              "conclusive_positive",
              "curated_positive",
              "conclusive_negative",
              "ambiguous",
              "missing",
              "contradictory",
              "timed_out",
              "uncalibrated",
              "below_threshold"
            ]
          },
          "evidence_envelope": { "type": "object" },
          "expected_verdict": { "type": "object" },
          "precalibration_runtime_state": {
            "enum": ["EXPLOIT_CONFIRMED", "INDETERMINATE"]
          },
          "live_campaign_result": { "type": "null" },
          "notes": { "type": "string", "minLength": 1, "maxLength": 2000 }
        }
      }
    }
  }
}
