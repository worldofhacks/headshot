{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentforge/contracts/v1/regression_disposition",
  "title": "RegressionDisposition",
  "version": "1",
  "description": "Deterministic regression-admission disposition. Admission is representable only when deterministic reproduction, passing for the right reason, and human approval are all true.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "disposition_id",
    "finding_id",
    "report_id",
    "campaign_run_id",
    "attempt_id",
    "state",
    "reason_codes",
    "reproduction_attempted",
    "deterministic_reproduction",
    "passes_for_right_reason",
    "human_approved",
    "admitted"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "disposition_id": { "type": "string", "minLength": 1, "maxLength": 80 },
    "finding_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "report_id": { "type": "string", "minLength": 1, "maxLength": 80 },
    "campaign_run_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "attempt_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "state": {
      "enum": [
        "pending_deterministic_reproduction",
        "rejected_non_deterministic",
        "rejected_wrong_reason",
        "blocked_pending_human_approval",
        "admitted"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "enum": [
          "deterministic_reproduction_not_run",
          "deterministic_reproduction_failed",
          "safe_behavior_not_observed_for_right_reason",
          "human_approval_required",
          "admission_requirements_satisfied"
        ]
      }
    },
    "reproduction_attempted": { "type": "boolean" },
    "deterministic_reproduction": { "type": "boolean" },
    "passes_for_right_reason": { "type": "boolean" },
    "human_approved": { "type": "boolean" },
    "admitted": { "type": "boolean" }
  },
  "allOf": [
    {
      "if": { "properties": { "state": { "const": "pending_deterministic_reproduction" } } },
      "then": {
        "properties": {
          "reproduction_attempted": { "const": false },
          "deterministic_reproduction": { "const": false },
          "passes_for_right_reason": { "const": false },
          "human_approved": { "const": false },
          "admitted": { "const": false }
        }
      }
    },
    {
      "if": { "properties": { "state": { "const": "rejected_non_deterministic" } } },
      "then": {
        "properties": {
          "reproduction_attempted": { "const": true },
          "deterministic_reproduction": { "const": false },
          "admitted": { "const": false }
        }
      }
    },
    {
      "if": { "properties": { "state": { "const": "rejected_wrong_reason" } } },
      "then": {
        "properties": {
          "reproduction_attempted": { "const": true },
          "deterministic_reproduction": { "const": true },
          "passes_for_right_reason": { "const": false },
          "admitted": { "const": false }
        }
      }
    },
    {
      "if": { "properties": { "state": { "const": "blocked_pending_human_approval" } } },
      "then": {
        "properties": {
          "reproduction_attempted": { "const": true },
          "deterministic_reproduction": { "const": true },
          "passes_for_right_reason": { "const": true },
          "human_approved": { "const": false },
          "admitted": { "const": false }
        }
      }
    },
    {
      "if": { "properties": { "state": { "const": "admitted" } } },
      "then": {
        "properties": {
          "reproduction_attempted": { "const": true },
          "deterministic_reproduction": { "const": true },
          "passes_for_right_reason": { "const": true },
          "human_approved": { "const": true },
          "admitted": { "const": true }
        }
      }
    }
  ]
}
