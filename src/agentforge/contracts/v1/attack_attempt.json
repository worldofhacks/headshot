{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentforge/contracts/v1/attack_attempt",
  "title": "AttackAttempt",
  "version": "1",
  "description": "RedTeam -> PolicyGateway. The attacker's PROPOSED input, nothing more. It carries no credentials and no evidence — the Red Team never reaches the target and never produces the AttemptResult (DECISIONS.md D14).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_ref", "input_sequence"],
  "properties": {
    "schema_version": { "const": "1" },
    "case_ref": { "type": "string", "minLength": 1 },
    "input_sequence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "mutation_lineage": { "type": "array", "items": { "type": "string" } },
    "category": { "type": "string" }
  }
}
