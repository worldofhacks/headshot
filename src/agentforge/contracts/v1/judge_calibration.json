{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentforge/contracts/v1/judge_calibration",
  "title": "JudgeCalibration",
  "version": "1",
  "description": "Offline Judge calibration result over versioned ground truth. Runtime model judgment is enabled only after thresholds pass, evaluator identity remains exact, and a human explicitly approves the result.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "calibration_id",
    "slice_set_sha256",
    "slice_refs",
    "judge_identity",
    "identity_sha256",
    "independent_from_red_team",
    "thresholds",
    "metrics",
    "category_metrics",
    "sample_results",
    "state",
    "reason_codes",
    "human_approved",
    "runtime_enabled",
    "approver_ref"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "calibration_id": { "type": "string", "pattern": "^JC-[0-9a-f]{64}$" },
    "slice_set_sha256": { "$ref": "#/$defs/sha256" },
    "slice_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": { "$ref": "#/$defs/slice_ref" }
    },
    "judge_identity": { "$ref": "#/$defs/judge_identity" },
    "identity_sha256": { "$ref": "#/$defs/sha256" },
    "independent_from_red_team": { "type": "boolean" },
    "thresholds": { "$ref": "#/$defs/thresholds" },
    "metrics": { "$ref": "#/$defs/metrics" },
    "category_metrics": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "metrics"],
        "properties": {
          "category": { "type": "string", "minLength": 1, "maxLength": 120 },
          "metrics": { "$ref": "#/$defs/metrics" }
        }
      }
    },
    "sample_results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/sample_result" }
    },
    "state": { "enum": ["passed", "failed", "invalidated"] },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "enum": [
          "thresholds_satisfied",
          "agreement_below_threshold",
          "false_positive_rate_exceeded",
          "false_negative_rate_exceeded",
          "calibration_error_exceeded",
          "abstention_rate_exceeded",
          "category_sample_floor_unmet",
          "confirmed_exploit_missed",
          "evaluator_not_independent",
          "identity_drift"
        ]
      }
    },
    "human_approved": { "type": "boolean" },
    "runtime_enabled": { "type": "boolean" },
    "approver_ref": { "type": ["string", "null"], "minLength": 1, "maxLength": 128 }
  },
  "allOf": [
    {
      "if": { "properties": { "runtime_enabled": { "const": true } } },
      "then": {
        "properties": {
          "state": { "const": "passed" },
          "human_approved": { "const": true },
          "approver_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": { "properties": { "state": { "enum": ["failed", "invalidated"] } } },
      "then": { "properties": { "runtime_enabled": { "const": false } } }
    },
    {
      "if": { "properties": { "human_approved": { "const": false } } },
      "then": { "properties": { "approver_ref": { "type": "null" } } }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "slice_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slice_id", "slice_version", "category", "sha256"],
      "properties": {
        "slice_id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "slice_version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "category": { "type": "string", "minLength": 1, "maxLength": 120 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "judge_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "judge_provider",
        "judge_model",
        "judge_model_version",
        "criteria_version",
        "implementation_version",
        "red_team_provider",
        "red_team_model"
      ],
      "properties": {
        "judge_provider": { "type": "string", "minLength": 1, "maxLength": 160 },
        "judge_model": { "type": "string", "minLength": 1, "maxLength": 160 },
        "judge_model_version": { "type": "string", "minLength": 1, "maxLength": 160 },
        "criteria_version": { "type": "string", "minLength": 1, "maxLength": 160 },
        "implementation_version": { "type": "string", "minLength": 1, "maxLength": 160 },
        "red_team_provider": { "type": "string", "minLength": 1, "maxLength": 160 },
        "red_team_model": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_agreement_rate",
        "max_false_positive_rate",
        "max_false_negative_rate",
        "max_expected_calibration_error",
        "max_abstention_rate",
        "min_samples_per_category"
      ],
      "properties": {
        "min_agreement_rate": { "$ref": "#/$defs/ratio" },
        "max_false_positive_rate": { "$ref": "#/$defs/ratio" },
        "max_false_negative_rate": { "$ref": "#/$defs/ratio" },
        "max_expected_calibration_error": { "$ref": "#/$defs/ratio" },
        "max_abstention_rate": { "$ref": "#/$defs/ratio" },
        "min_samples_per_category": { "type": "integer", "minimum": 1, "maximum": 10000 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_count",
        "agreement_count",
        "agreement_rate",
        "false_positive_count",
        "false_positive_rate",
        "false_negative_count",
        "false_negative_rate",
        "abstention_count",
        "abstention_rate",
        "expected_calibration_error"
      ],
      "properties": {
        "sample_count": { "type": "integer", "minimum": 0 },
        "agreement_count": { "type": "integer", "minimum": 0 },
        "agreement_rate": { "$ref": "#/$defs/ratio" },
        "false_positive_count": { "type": "integer", "minimum": 0 },
        "false_positive_rate": { "$ref": "#/$defs/ratio" },
        "false_negative_count": { "type": "integer", "minimum": 0 },
        "false_negative_rate": { "$ref": "#/$defs/ratio" },
        "abstention_count": { "type": "integer", "minimum": 0 },
        "abstention_rate": { "$ref": "#/$defs/ratio" },
        "expected_calibration_error": { "$ref": "#/$defs/ratio" }
      }
    },
    "sample_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label_id",
        "category",
        "expected_state",
        "actual_state",
        "confidence",
        "agreement",
        "false_positive",
        "false_negative",
        "abstained"
      ],
      "properties": {
        "label_id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "category": { "type": "string", "minLength": 1, "maxLength": 120 },
        "expected_state": {
          "enum": ["EXPLOIT_CONFIRMED", "EXPLOIT_LIKELY", "NO_EXPLOIT_OBSERVED", "INDETERMINATE", "ERROR"]
        },
        "actual_state": {
          "enum": ["EXPLOIT_CONFIRMED", "EXPLOIT_LIKELY", "NO_EXPLOIT_OBSERVED", "INDETERMINATE", "ERROR"]
        },
        "confidence": { "$ref": "#/$defs/ratio" },
        "agreement": { "type": "boolean" },
        "false_positive": { "type": "boolean" },
        "false_negative": { "type": "boolean" },
        "abstained": { "type": "boolean" }
      }
    }
  }
}
