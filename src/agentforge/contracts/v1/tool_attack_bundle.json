{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://headshot.security/contracts/v1/tool_attack_bundle.json",
  "title": "ToolAttackBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "tool_name",
    "tool_version",
    "configuration_sha256",
    "generated_at",
    "artifact_sha256",
    "source_kind",
    "candidate_provenance",
    "target_access",
    "candidates"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "bundle_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "tool_name": {"type": "string", "minLength": 1, "maxLength": 64},
    "tool_version": {"type": "string", "minLength": 1, "maxLength": 64},
    "configuration_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "artifact_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_kind": {"const": "security_tool"},
    "candidate_provenance": {"const": "tool_generated"},
    "target_access": {"const": "policy_gateway_only"},
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "tool_name",
          "tool_version",
          "technique",
          "category",
          "input_sequence",
          "owasp_mappings",
          "source_ref",
          "source_artifact_sha256",
          "provenance_sha256",
          "deterministic"
        ],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1, "maxLength": 160},
          "tool_name": {"type": "string", "minLength": 1, "maxLength": 64},
          "tool_version": {"type": "string", "minLength": 1, "maxLength": 64},
          "technique": {"type": "string", "minLength": 1, "maxLength": 200},
          "category": {
            "enum": [
              "prompt_injection",
              "data_exfiltration",
              "state_corruption",
              "tool_misuse",
              "denial_of_service",
              "identity_role_exploitation"
            ]
          },
          "input_sequence": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "items": {"type": "string", "minLength": 1, "maxLength": 20000}
          },
          "owasp_mappings": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(A(0[1-9]|10)|LLM(0[1-9]|10))(:2021|:2025)?$"
            }
          },
          "source_ref": {"type": "string", "minLength": 1, "maxLength": 500},
          "source_artifact_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "provenance_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "deterministic": {"type": "boolean"}
        }
      }
    }
  }
}
