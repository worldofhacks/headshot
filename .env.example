# ============================================================
# HEADSHOT — LOCAL SECRETS AND RUNTIME CONFIGURATION (template)
# Copy:  cp .env.example .env.local     then edit .env.local ONLY.
# NEVER commit .env.local, and NEVER put real values in .env.example.
# .gitignore already ignores .env.local (every .env.* except this file).
#
# AGENTFORGE_* and Clerk variables marked OPERATIONAL below are consumed today.
# HEADSHOT_*/provider entries in blocks marked RESERVED remain forward-looking;
# treat those as non-operational until their stated milestone ships.
# ============================================================

# ------------------------------------------------------------
# Core runtime — M1a   (OPERATIONAL: read by code today)
# ------------------------------------------------------------
# Deployment environment. Enumerated: local | staging | production (default: local).
# Read by src/agentforge/config.py (Settings.from_env). Gates the O1 credential-
# isolation invariant: only 'production' may resolve production target credentials.
AGENTFORGE_ENVIRONMENT=local

# Local Postgres DSN. Matches compose.yaml (user/password/db =
# agentforge / local_dev_only / agentforge). 'local_dev_only' is a throwaway
# local-dev password already committed in compose.yaml — NOT a real secret.
# Read by src/agentforge/app.py. Host 'localhost' when the app runs on the host;
# use host 'postgres' when the app runs inside compose.
DATABASE_URL=postgresql://agentforge:local_dev_only@localhost:5432/agentforge

# Optional contracts-directory override. Leave EMPTY to use the repository
# contracts/v1 directory. Read by src/agentforge/contracts/registry.py.
AGENTFORGE_CONTRACTS_DIR=

# ------------------------------------------------------------
# WEB + CLERK HUMAN AUTHENTICATION — M1d (OPERATIONAL)
# Request authentication reads explicit process environment values only. For the
# container stack, run `docker compose --env-file .env.local up --build`; Compose
# passes only its enumerated Web values and never the provider/target values below.
# Staging/production values belong in separate Railway sealed variables.
# ------------------------------------------------------------
# Railway assigns PORT in deployment. The local built-console stack uses 8000.
PORT=8000

# Host-source runs resolve this repository-relative build output. The production
# image and Compose pin the immutable packaged location `/app/console` instead.
AGENTFORGE_CONSOLE_DIR=console/dist

# Maximum request body accepted by the public Web boundary (1 KiB–10 MiB).
AGENTFORGE_MAX_REQUEST_BYTES=1048576

# Public browser identifier embedded by the Vite build. It carries no backend authority.
VITE_CLERK_PUBLISHABLE_KEY=

# Backend copy of the environment's public publishable identifier. Local/staging
# must use pk_test_; production must use pk_live_.
CLERK_PUBLISHABLE_KEY=

# Clerk Dashboard PEM public key used for networkless RS256 verification. Keep this
# blank in the committed template. Literal \n separators are accepted when a secret
# store cannot preserve multiline values.
CLERK_JWT_KEY=

# Exact comma-separated browser origins; never use a wildcard. This same-origin
# Compose example is served at port 8000. Deployed origins must be HTTPS.
CLERK_AUTHORIZED_PARTIES=http://localhost:8000

# Exact Organization ID for the environment's Headshot Organization.
CLERK_REQUIRED_ORG_ID=

# Exact Clerk Frontend API HTTPS origin used by CSP `connect-src`; no path or wildcard.
# This is the environment-specific FAPI origin associated with the publishable key.
CLERK_FRONTEND_API_ORIGIN=

# Required isolation guards in staging. They let config reject accidental reuse of
# the production Organization or any production browser origin.
CLERK_PRODUCTION_ORG_ID=
CLERK_PRODUCTION_AUTHORIZED_PARTIES=

# CLERK_SECRET_KEY is deliberately NOT required or read for request authentication.
# Add it later only as a sealed variable if Backend API invitation/user management
# is implemented; never expose it to Vite or the browser.

# ------------------------------------------------------------
# RED TEAM INFERENCE — RESERVED, consumer lands in M8
# Recommended MVP provider: OpenRouter (hosted-OSS). The API key MUST be a
# dedicated inference key with an expiry and a spending limit — never an
# OpenRouter management key.
# ------------------------------------------------------------
# Provider selector is provider-NEUTRAL: HEADSHOT_RED_TEAM_PROVIDER picks the adapter,
# HEADSHOT_RED_TEAM_MODEL is the single canonical model id (NO provider-specific alias —
# no OPENROUTER_MODEL). M8 maps HEADSHOT_RED_TEAM_MODEL into the selected provider adapter
# and validates the provider/model pair. The API key stays provider-named.
HEADSHOT_RED_TEAM_PROVIDER=openrouter
HEADSHOT_RED_TEAM_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# If Together is selected instead, set HEADSHOT_RED_TEAM_PROVIDER=together
# and populate the key below.
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1

# Provider/runtime limits. The trusted Policy Gateway (M4) remains authoritative;
# these do NOT replace its budget/rate controls.
HEADSHOT_RED_TEAM_REQUEST_TIMEOUT_SECONDS=60
HEADSHOT_RED_TEAM_MAX_RETRIES=2

# ------------------------------------------------------------
# INDEPENDENT JUDGE — RESERVED, consumer lands in M9
# Keep the Judge credential/provider SEPARATE from the Red Team. Judge
# independence is a hard gate: an agent that both attacks and judges is
# compromised by design.
# ------------------------------------------------------------
HEADSHOT_JUDGE_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Configurable default (not a hard-coded runtime requirement): recommended `claude-sonnet-5`
# (its predecessor `claude-sonnet-4-6` remains available). The Judge model is chosen by measured
# calibration/false-negative-rate, not refusal behavior (D8/D13).
HEADSHOT_JUDGE_MODEL=
HEADSHOT_JUDGE_REQUEST_TIMEOUT_SECONDS=60

# ------------------------------------------------------------
# LANGFUSE CLOUD / OBSERVABILITY — RESERVED, consumer lands in M6b
# Synthetic and redacted telemetry only — never real PHI.
# ------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=local

# ------------------------------------------------------------
# LIVE TARGET — RESERVED. Consumers by milestone:
#   M4  Policy Gateway + Execution Recorder — allowlist, HEADSHOT_TARGET_ID, and
#       scoped-credential resolution; verified against the P9 fake.
#   M5  OpenEMR live adapter — HEADSHOT_TARGET_AUTH_MODE and the OPENEMR_* auth
#       secrets (bearer / session / oauth).
#   D1  Deployed live target URL (HEADSHOT_TARGET_BASE_URL) readiness.
# Do NOT populate or use until live probing is explicitly authorized AND M4 passes
# completely against the P9 fake. Locally the P9 deterministic fake is the ONLY
# target available — no live URL, no live credential.
# ------------------------------------------------------------
HEADSHOT_TARGET_ID=openemr-copilot
HEADSHOT_TARGET_BASE_URL=
# Valid auth modes: none | bearer | session | oauth
HEADSHOT_TARGET_AUTH_MODE=none

# The allowlist references the target by HEADSHOT_TARGET_ID. The credential
# REFERENCE is a lookup handle (env:VARNAME), never an inline secret — the
# referenced variable holds the value, keeping secrets out of the reference.
HEADSHOT_TARGET_CREDENTIAL_REF=env:OPENEMR_TARGET_CREDENTIAL
OPENEMR_TARGET_CREDENTIAL=

# Auth-specific alternatives (consumed by the M5 OpenEMR adapter). Populate ONLY
# the mode actually used.
OPENEMR_BEARER_TOKEN=
OPENEMR_SESSION_COOKIE=
OPENEMR_OAUTH_CLIENT_ID=
OPENEMR_OAUTH_CLIENT_SECRET=
OPENEMR_OAUTH_TOKEN_URL=

# Synthetic fixtures and deterministic canary (no real PHI, ever).
HEADSHOT_SYNTHETIC_ONLY=true
HEADSHOT_CANARY_VALUE=

# Live-campaign safety limits — enforced by the Policy Gateway / authorized-live-
# campaign gate (M4). No live run may start when these are missing, malformed,
# zero/negative, or above policy maxima. Left EMPTY here on purpose (no unsafe default).
HEADSHOT_RUN_BUDGET_USD=
HEADSHOT_MAX_ATTEMPTS_PER_RUN=
HEADSHOT_TARGET_REQUESTS_PER_SECOND=
HEADSHOT_RUN_TIMEOUT_SECONDS=

# ------------------------------------------------------------
# FINAL-PHASE PROVIDERS — RESERVED, consumer lands in Final
# (Documentation agent -> F2; Orchestrator -> Final). Not required for the
# local MVP spine.
# ------------------------------------------------------------
OPENAI_API_KEY=
# Configurable defaults (not hard-coded): Documentation recommended `gpt-5.4` (OpenAI — a DIFFERENT
# vendor from the Judge, so a single-vendor failure can't take out both; D8/S5 defense-in-depth);
# Orchestrator recommended `claude-opus-4-8`. Leave empty to defer selection to deployment config.
HEADSHOT_DOCUMENTATION_MODEL=
HEADSHOT_ORCHESTRATOR_MODEL=
