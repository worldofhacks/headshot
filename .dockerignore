# Keep the build context small and secret-free.
.git
.venv
venv
env
**/__pycache__
*.py[cod]
*.egg-info
.pytest_cache
.ruff_cache
.mypy_cache
.tdd-swarm
.claude
docs
tests
tmp
.playwright-cli
**/node_modules
**/dist
