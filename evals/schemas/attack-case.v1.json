{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentforge/evals/schemas/attack-case/v1",
  "title": "AttackCase",
  "description": "Authoritative offline AttackCase for the M11 seed corpus. Authored expectations are not observed live evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "case_version",
    "lifecycle_status",
    "artifact_kind",
    "category",
    "subcategory",
    "target_surface",
    "sequence_type",
    "input_sequence_trust",
    "input_sequence",
    "adversarial_goal",
    "expected_safe_behavior",
    "expected_evidence",
    "severity",
    "exploitability",
    "test_design",
    "owasp",
    "oracle_expectation",
    "regression_promotion",
    "fixture_provenance",
    "authorization_posture",
    "expected_typed_failure",
    "ground_truth_refs",
    "execution_status",
    "observed_behavior",
    "result_kind",
    "result_ref"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "case_id": { "type": "string", "pattern": "^AF-M11-[A-Z0-9-]+$", "maxLength": 80 },
    "case_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "lifecycle_status": { "enum": ["draft", "active", "retired"] },
    "artifact_kind": { "const": "authored_eval_case" },
    "category": {
      "enum": [
        "prompt_injection",
        "data_exfiltration",
        "state_corruption",
        "tool_misuse",
        "denial_of_service",
        "identity_role_exploitation"
      ]
    },
    "subcategory": {
      "enum": [
        "direct",
        "indirect",
        "multi_turn",
        "phi_leakage",
        "cross_patient_exposure",
        "authorization_bypass",
        "conversation_history_manipulation",
        "context_poisoning",
        "unintended_invocation",
        "parameter_tampering",
        "recursive_calls",
        "token_exhaustion",
        "cost_amplification",
        "privilege_escalation",
        "persona_hijacking",
        "trust_boundary_violation"
      ]
    },
    "target_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_ref", "capability", "trust_boundary", "attack_surface"],
      "properties": {
        "target_ref": { "const": "openemr-clinical-copilot" },
        "capability": {
          "enum": [
            "rag_retrieval",
            "uploaded_content",
            "conversation_memory",
            "clinical_writeback",
            "tool_invocation",
            "authorization_scope",
            "system_prompt"
          ]
        },
        "trust_boundary": {
          "enum": [
            "untrusted_content_to_model",
            "conversation_to_persistent_context",
            "patient_scope_to_retrieval",
            "model_to_tool",
            "tool_parameters_to_clinical_record",
            "target_output_to_evaluator"
          ]
        },
        "attack_surface": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "sequence_type": { "enum": ["single_turn", "multi_turn"] },
    "input_sequence_trust": { "const": "hostile" },
    "input_sequence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 20000 }
    },
    "adversarial_goal": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "expected_safe_behavior": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "expected_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_sources", "safe_signals", "exploit_signals"],
      "properties": {
        "required_sources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["policy_gateway", "execution_recorder", "oracle", "canary", "judge"]
          }
        },
        "safe_signals": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
        },
        "exploit_signals": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "severity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rating", "rationale"],
      "properties": {
        "rating": { "enum": ["low", "medium", "high", "critical"] },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "exploitability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rating", "rationale", "preconditions"],
      "properties": {
        "rating": { "enum": ["low", "medium", "high"] },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "preconditions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "test_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "adversarial",
        "security_property",
        "adversarial_condition",
        "failure_condition"
      ],
      "properties": {
        "classification": { "enum": ["boundary", "invariant", "regression"] },
        "adversarial": { "const": true },
        "security_property": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "adversarial_condition": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "failure_condition": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "owasp": {
      "type": "array",
      "minItems": 2,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/owasp_tag" }
    },
    "oracle_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "availability",
        "deterministic",
        "oracle_id",
        "canary_ref",
        "expected_signal",
        "live_target_provisioning"
      ],
      "properties": {
        "kind": {
          "enum": [
            "none",
            "synthetic_canary_match",
            "system_prompt_canary_match",
            "forbidden_tool_call",
            "patient_scope_violation"
          ]
        },
        "availability": { "enum": ["unavailable", "local_fixture_only", "pending_runtime"] },
        "deterministic": { "type": "boolean" },
        "oracle_id": { "type": ["string", "null"], "maxLength": 120 },
        "canary_ref": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^SYNTH_CANARY_[A-Z0-9_]+$", "maxLength": 120 }
          ]
        },
        "expected_signal": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "live_target_provisioning": {
          "enum": ["not_applicable", "pending_authorization", "unavailable"]
        }
      }
    },
    "regression_promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eligible_if_confirmed",
        "add_to_regression",
        "requires_deterministic_reproduction",
        "requires_pass_for_right_reason"
      ],
      "properties": {
        "eligible_if_confirmed": { "type": "boolean" },
        "add_to_regression": { "type": "boolean" },
        "requires_deterministic_reproduction": { "const": true },
        "requires_pass_for_right_reason": { "const": true }
      }
    },
    "fixture_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "fixture_id",
        "fixture_version",
        "source",
        "contains_real_phi"
      ],
      "properties": {
        "classification": { "const": "synthetic" },
        "fixture_id": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62})$",
          "maxLength": 63
        },
        "fixture_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source": { "enum": ["hand_authored", "deterministic_generator"] },
        "contains_real_phi": { "const": false }
      }
    },
    "authorization_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["live_execution", "live_execution_authorized", "required_controls"],
      "properties": {
        "live_execution": { "const": "explicit_authorization_required" },
        "live_execution_authorized": { "const": false },
        "required_controls": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "allowlist",
              "synthetic_data",
              "scoped_credentials",
              "budget_cap",
              "rate_cap",
              "timeout",
              "monitoring",
              "hard_abort"
            ]
          }
        }
      }
    },
    "expected_typed_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fail_closed",
        "valid_inconclusive_disposition",
        "malformed_evidence_disposition",
        "malformed_evidence_error_code"
      ],
      "properties": {
        "fail_closed": { "const": true },
        "valid_inconclusive_disposition": { "const": "INDETERMINATE" },
        "malformed_evidence_disposition": { "const": "ERROR" },
        "malformed_evidence_error_code": {
          "enum": ["evidence-missing", "evidence-integrity-failed"]
        }
      }
    },
    "ground_truth_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^GT-M11-[A-Z0-9-]+$" }
    },
    "execution_status": {
      "enum": ["NOT_EXECUTED", "EXECUTED_LOCAL_FIXTURE", "EXECUTED_LIVE"]
    },
    "observed_behavior": { "enum": [null, "pass", "fail", "partial"] },
    "result_kind": {
      "enum": ["pending_live_campaign", "local_deterministic_fixture", "live_campaign"]
    },
    "result_ref": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{0,119}$" }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "execution_status": { "const": "NOT_EXECUTED" } } },
      "then": {
        "properties": {
          "observed_behavior": { "const": null },
          "result_kind": { "const": "pending_live_campaign" },
          "result_ref": { "const": null },
          "regression_promotion": {
            "properties": { "add_to_regression": { "const": false } }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "execution_status": { "const": "EXECUTED_LOCAL_FIXTURE" } }
      },
      "then": {
        "properties": {
          "observed_behavior": { "enum": ["pass", "fail", "partial"] },
          "result_kind": { "const": "local_deterministic_fixture" },
          "result_ref": { "type": "string" }
        }
      }
    },
    {
      "if": { "properties": { "execution_status": { "const": "EXECUTED_LIVE" } } },
      "then": {
        "properties": {
          "observed_behavior": { "enum": ["pass", "fail", "partial"] },
          "result_kind": { "const": "live_campaign" },
          "result_ref": { "type": "string" }
        }
      }
    }
  ],
  "$defs": {
    "owasp_tag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework", "version", "id", "name"],
      "properties": {
        "framework": { "enum": ["OWASP Web", "OWASP LLM"] },
        "version": { "enum": ["2021", "2025"] },
        "id": { "type": "string", "minLength": 1, "maxLength": 10 },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 }
      }
    }
  }
}
